#: panel-plugin/xfce4-clipman-settings.desktop.in:5
msgid "Customize your clipboard"
msgstr "ປັບແຕ່ງຄລິບບອດຂອງທ່ານ"

#: panel-plugin/settings-dialog.ui:30
msgid "Clipman Settings"
msgstr "ການຕັ້ງຄ່າ Clipman"

#: panel-plugin/settings-dialog.ui:65
msgid "_Close"
msgstr "_ປິດ"

#: panel-plugin/settings-dialog.ui:117
msgid "Sync mouse _selections"
msgstr "_ປະສານຂໍ້ມູນການເລືອກດ້ວຍເມົາສ໌"

#: panel-plugin/settings-dialog.ui:122
msgid ""
"If checked, selections will be synced with the default clipboard, so you can"
" paste what you select with Ctrl-V. Conversely, manual copies will be synced"
" with the primary clipboard, so you can paste what you copy with middle-"
"click."
msgstr "ຫາກເລືອກ, ສິ່ງທີ່ເລືອກຈະຖືກປະສານຂໍ້ມູນກັບຄລິບບອດມາດຕະຖານ, ເພື່ອໃຫ້ທ່ານສາມາດວາງສິ່ງທີ່ເລືອກດ້ວຍ Ctrl-V. ໃນທາງກັບກັນ, ການສຳເນົາດ້ວຍມືຈະຖືກປະສານຂໍ້ມູນກັບຄລິບບອດຫຼັກ, ເພື່ອໃຫ້ທ່ານສາມາດວາງສິ່ງທີ່ທ່ານສຳເນົາດ້ວຍການຄລິກປຸ່ມກາງຂອງເມົາສ໌."

#: panel-plugin/settings-dialog.ui:134
msgid "_Persist mouse selections"
msgstr "_ຮັກສາສິ່ງທີ່ເລືອກດ້ວຍເມົາສ໌ໄວ້"

#: panel-plugin/settings-dialog.ui:139
msgid ""
"If checked, the primary clipboard (middle-click paste) will persist until "
"next selection if current selection is lost (e.g. by left-clicking anywhere "
"in a text area)"
msgstr "ຫາກເລືອກ, ຄລິບບອດຫຼັກ (ວາງດ້ວຍປຸ່ມກາງ) ຈະຍັງຄົງຢູ່ຈົນກວ່າຈະມີການເລືອກໃໝ່ ຫາກສິ່ງທີ່ເລືອກໃນປັດຈຸບັນຫາຍໄປ (ຕົວຢ່າງ: ການຄລິກຊ້າຍໃສ່ບ່ອນໃດນຶ່ງໃນເຂດຂໍ້ຄວາມ)"

#: panel-plugin/settings-dialog.ui:151
msgid "_QR-Code support"
msgstr "ການຮອງຮັບ _QR-Code"

#: panel-plugin/settings-dialog.ui:156
msgid ""
"If checked, the menu shows a QR-Code of the currently selected clipboard "
"entry"
msgstr "ຫາກເລືອກ, ເມນູຈະສະແດງ QR-Code ຂອງລາຍການຄລິບບອດທີ່ຖືກເລືອກໃນປັດຈຸບັນ"

#: panel-plugin/settings-dialog.ui:170
msgid "Automatically paste a selected item from the history"
msgstr "ວາງລາຍການທີ່ເລືອກຈາກປະຫວັດໂດຍອັດຕະໂນມັດ"

#: panel-plugin/settings-dialog.ui:176
msgid "_Paste instantly:"
msgstr "_ວາງທັນທີ:"

#: panel-plugin/settings-dialog.ui:214
msgid "<b>General</b>"
msgstr "<b>ທົ່ວໄປ</b>"

#: panel-plugin/settings-dialog.ui:245
msgid "P_osition menu at mouse pointer"
msgstr "ຕັ້ງ_ຕຳແໜ່ງເມນູໄວ້ທີ່ຕົວຊີ້ເມົາສ໌"

#: panel-plugin/settings-dialog.ui:249
msgid ""
"Popup the menu at the mouse pointer position: especially useful for the "
"xfce4-popup-clipman command"
msgstr "ສະແດງເມນູປັອບອັບຢູ່ຕຳແໜ່ງຕົວຊີ້ເມົາສ໌: ເປັນປະໂຫຍດຫຼາຍສຳລັບຄຳສັ່ງ xfce4-popup-clipman"

#: panel-plugin/settings-dialog.ui:267
msgid "Maximum items:"
msgstr "ຈຳນວນລາຍການສູງສຸດ:"

#: panel-plugin/settings-dialog.ui:304
msgid "<b>Menu</b>"
msgstr "<b>ເມນູ</b>"

#: panel-plugin/settings-dialog.ui:321
msgid "_Behavior"
msgstr "_ພຶດຕິກຳ"

#: panel-plugin/settings-dialog.ui:343
msgid "<b>_Enable automatic actions</b>"
msgstr "<b>_ເປີດໃຊ້ການກະທຳອັດຕະໂນມັດ</b>"

#: panel-plugin/settings-dialog.ui:358
msgid ""
"If checked, the clipboard texts will be matched against regular expressions and a menu will display possible actions automatically.\n"
"Otherwise the menu will only appear when calling \"xfce4-popup-clipman-actions\" (and a match was found)"
msgstr "ຫາກເລືອກ, ຂໍ້ຄວາມໃນຄລິບບອດຈະຖືກນຳໄປຈັບຄູ່ກັບນິພົດປົກກະຕິ ແລະ ເມນູຈະສະແດງການກະທຳທີ່ເປັນໄປໄດ້ໂດຍອັດຕະໂນມັດ.\nຖ້າບໍ່ດັ່ງນັ້ນ ເມນູຈະປາກົດຂຶ້ນເມື່ອເອີ້ນໃຊ້ \"xfce4-popup-clipman-actions\" ເທົ່ານັ້ນ (ແລະ ເມື່ອພົບການຈັບຄູ່)"

#: panel-plugin/settings-dialog.ui:384
msgid ""
"When the selection is done and the Control key is still pressed down, the "
"popup menu for matched actions will be shown or hidden"
msgstr "ເມື່ອການເລືອກສຳເລັດ ແລະ ຍັງກົດປຸ່ມ Control ຄ້າງໄວ້, ເມນູປັອບອັບສຳລັບການກະທຳທີ່ກົງກັນຈະຖືກສະແດງ ຫຼື ເຊື່ອງ"

#: panel-plugin/settings-dialog.ui:390
msgid "_Pressing Ctrl during selection:"
msgstr "_ກົດ Ctrl ໃນຂະນະທີ່ເລືອກ:"

#: panel-plugin/settings-dialog.ui:459
msgid "Add action"
msgstr "ເພີ່ມການກະທຳ"

#: panel-plugin/settings-dialog.ui:481
msgid "Edit action"
msgstr "ແກ້ໄຂການກະທຳ"

#: panel-plugin/settings-dialog.ui:503
msgid "Delete action"
msgstr "ລຶບການກະທຳ"

#: panel-plugin/settings-dialog.ui:524
msgid "Reset all actions to the system default values"
msgstr "ຕັ້ງຄ່າການກະທຳທັງໝົດຄືນໃໝ່ເປັນຄ່າເລີ່ມຕົ້ນຂອງລະບົບ"

#: panel-plugin/settings-dialog.ui:571
msgid "_Actions"
msgstr "_ການກະທຳ"

#: panel-plugin/settings-dialog.ui:594
msgid "<b>Remember history</b>"
msgstr "<b>ຈົດຈຳປະຫວັດ</b>"

#: panel-plugin/settings-dialog.ui:631
msgid "Remember last copied _image"
msgstr "ຈົດຈຳ_ຮູບພາບທີ່ສຳເນົາຫຼ້າສຸດ"

#: panel-plugin/settings-dialog.ui:635
msgid ""
"If checked, this option allows one to store one image inside the history"
msgstr "ຖ້າໝາຍເລືອກ, ຕົວເລືອກນີ້ຈະອະນຸຍາດໃຫ້ເກັບຮູບພາບໜຶ່ງຮູບໄວ້ໃນປະຫວັດ."

#: panel-plugin/settings-dialog.ui:647
msgid "_Reorder history items"
msgstr "_ຈັດລຽງລຳດັບປະຫວັດໃໝ່"

#: panel-plugin/settings-dialog.ui:651
msgid ""
"Push last copied text to the top of the history, useful to reorder old items"
msgstr "ດັນຂໍ້ຄວາມທີ່ສຳເນົາຫຼ້າສຸດໄປໄວ້ທາງເທິງຂອງປະຫວັດ, ມີປະໂຫຍດໃນການຈັດລຽງລາຍການເກົ່າຄືນໃໝ່"

#: panel-plugin/settings-dialog.ui:663
msgid "Re_verse history order"
msgstr "_ປີ້ນລຳດັບປະຫວັດ"

#: panel-plugin/settings-dialog.ui:667
msgid "Reverse order of the history shown in the menu"
msgstr "ປີ້ນລຳດັບຂອງປະຫວັດທີ່ສະແດງໃນເມນູ"

#: panel-plugin/settings-dialog.ui:679
msgid "Ignore mouse s_elections"
msgstr "ລະເວັ້ນການເ_ລືອກດ້ວຍເມົາສ໌"

#: panel-plugin/settings-dialog.ui:684
msgid ""
"If checked, the selections won't affect the history except the manual copies"
msgstr "ຫາກເລືອກ, ສິ່ງທີ່ເລືອກຈະບໍ່ມີຜົນຕໍ່ປະຫວັດ ຍົກເວັ້ນການສຳເນົາດ້ວຍມື"

#: panel-plugin/settings-dialog.ui:703
msgid "Size of the _history:"
msgstr "ຂະໜາດຂອງ_ປະຫວັດ:"

#: panel-plugin/settings-dialog.ui:719
msgid "5"
msgstr "5"

#: panel-plugin/settings-dialog.ui:753
msgid "H_istory"
msgstr "ປະ_ຫວັດ"

#: panel-plugin/settings-dialog.ui:777
msgid "Edit Action"
msgstr "ແກ້ໄຂການກະທຳ"

#: panel-plugin/settings-dialog.ui:803 panel-plugin/settings-dialog.ui:1298
msgid "_Cancel"
msgstr "_ຍົກເລີກ"

#: panel-plugin/settings-dialog.ui:817 panel-plugin/settings-dialog.ui:1312
msgid "_OK"
msgstr "_ຕົກລົງ"

#: panel-plugin/settings-dialog.ui:886 panel-plugin/settings-dialog.ui:1114
msgid "Name:"
msgstr "ຊື່:"

#: panel-plugin/settings-dialog.ui:898
msgid "Pattern:"
msgstr "ຮູບແບບ:"

#: panel-plugin/settings-dialog.ui:985
msgid ""
"You can use the substitution parameters \"\\1\", \"\\2\" and so on in the "
"commands. The parameter \"\\0\" represents the complete text. The pattern is"
" always anchored within the special characters ^$"
msgstr "ທ່ານສາມາດໃຊ້ພາຣາມິເຕີແທນທີ່ \"\\1\", \"\\2\" ແລະ ຕໍ່ໆໄປໃນຄຳສັ່ງໄດ້. ພາຣາມິເຕີ \"\\0\" ໝາຍເຖິງຂໍ້ຄວາມທັງໝົດ. ຮູບແບບຈະຖືກກຳນົດຂອບເຂດດ້ວຍຕົວອັກສອນພິເສດ ^$ ສະເໝີ"

#: panel-plugin/settings-dialog.ui:1011
msgid "Activate on manual copy instead of selection"
msgstr "ເປີດໃຊ້ງານເມື່ອສຳເນົາດ້ວຍມື ແທນການເລືອກຂໍ້ຄວາມ"

#: panel-plugin/settings-dialog.ui:1016
msgid ""
"By default the action is triggered by a selection: check this option to "
"trigger the action when you make a manual copy instead. Note that in this "
"case, the Control key no longer has any effect."
msgstr "ໂດຍປົກກະຕິ ການກະທຳຈະຖືກກະຕຸ້ນດ້ວຍການເລືອກຂໍ້ຄວາມ: ເລືອກຕົວເລືອກນີ້ເພື່ອໃຫ້ການກະທຳເຮັດວຽກເມື່ອທ່ານສຳເນົາດ້ວຍມືແທນ. ໝາຍເຫດວ່າໃນກໍລະນີນີ້, ປຸ່ມ Control ຈະບໍ່ມີຜົນໃດໆອີກຕໍ່ໄປ."

